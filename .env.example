# === Netease Cloud Music API ===
# Required. Local development: http://localhost:3000
# Docker deployment: http://netease-api:3000
NETEASE_API_URL=http://localhost:3000

# === Gemini API ===
# Required. Get an API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === Server ===
# Optional. Backend HTTP port.
PORT=3000

# Optional. Use development locally, production in deployed environments.
NODE_ENV=development

# CORS allowed origins (comma-separated, production only)
CORS_ORIGIN=https://yourdomain.com

# === Database ===
# Optional. SQLite file path relative to backend/.
DB_PATH=./data/radio.db

# === TTS Cache ===
# Optional. Edge TTS generated audio cache directory relative to backend/.
TTS_CACHE_DIR=./data/tts-cache

# === Logging ===
# Optional. Use debug for local development; use info or warn in production.
LOG_LEVEL=debug

# === Security ===
# Optional. 32+ character cookie encryption key.
# If omitted, cookies may be stored in plain text until encryption is implemented.
# COOKIE_ENCRYPTION_KEY=your_random_32_char_string
